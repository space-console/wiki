{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [ "**/*.md", "**/toc.yml" ],
        "exclude": [
          "_site/**",
          "**/bin/**",
          "**/obj/**",
          "**/node_modules/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [ "docs/images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "Space Console Wiki",
      "_appTitle": "Space Console Wiki",
      "_enableSearch": true,
      "_disableContribution": false
    },
    "markdownEngineName": "markdig"
  }
}
