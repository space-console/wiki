{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [ "**/*.md", "**/toc.yml" ],
        "exclude": [
          "_site/**",
          "**/bin/**",
          "**/obj/**",
          "**/node_modules/**",
          "CLAUDE.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [ "docs/images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern", "templates/spacedeck" ],
    "globalMetadata": {
      "_appName": "SPACE CONSOLE",
      "_appTitle": "Space Console · Mission Control",
      "_enableSearch": true,
      "_disableContribution": true,
      "_disableNewTab": false,
      "_appFooter": "<span>SPACE CONSOLE // MISSION CONTROL — telemetry nominal</span>"
    },
    "markdownEngineName": "markdig"
  }
}
